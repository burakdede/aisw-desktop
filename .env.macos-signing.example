# Copy to .env.macos-signing and replace placeholders.
# Prefer *_FILE for secrets you do not want inline here.

APPLE_CERTIFICATE_PATH=/absolute/path/to/DeveloperID.p12
APPLE_CERTIFICATE_PASSWORD_FILE=secrets/apple-certificate-password.txt
APPLE_SIGNING_IDENTITY='Developer ID Application: Example, Inc. (TEAMID1234)'
APPLE_ID=ship@example.com
APPLE_PASSWORD_FILE=secrets/apple-app-password.txt
APPLE_TEAM_ID=TEAMID1234
