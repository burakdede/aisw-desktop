{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AISW Desktop",
  "version": "0.1.0",
  "identifier": "com.aisw.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AISW Desktop",
        "width": 980,
        "height": 680,
        "minWidth": 820,
        "minHeight": 560,
        "titleBarStyle": "transparent",
        "hiddenTitle": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/aisw"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "channels": {},
      "endpoints": [],
      "pubkey": ""
    }
  }
}
