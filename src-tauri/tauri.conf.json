{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Switcher",
  "mainBinaryName": "AI Switcher",
  "version": "0.1.11",
  "identifier": "com.aiswitch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Switcher",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "bundleName": "AI Switcher",
      "infoPlist": "Info.plist"
    },
    "externalBin": [
      "binaries/aisw"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "channels": {},
      "endpoints": [],
      "pubkey": ""
    }
  }
}
